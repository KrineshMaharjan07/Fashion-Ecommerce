# ============================================================
# .env.local — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── MongoDB Atlas ─────────────────────────────────────────────
# 1. Go to https://cloud.mongodb.com and create a FREE cluster
# 2. Click "Connect" → "Drivers" → copy the connection string
# 3. Replace <password> with your database user password
# 4. Replace myFirstDatabase with: atelier-noir
MONGODB_URI=mongodb+srv://admin:adminisking@cluster0.xxxxx.mongodb.net/atelier-noir?retryWrites=true&w=majority

# ── Admin credentials (change these!) ────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=atelier2024

# ── JWT secret (generate a random 32+ char string) ───────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── Email (Gmail SMTP with App Password) ─────────────────────
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-business@gmail.com
EMAIL_PASS=your-gmail-app-password

# ── Business info ─────────────────────────────────────────────
BUSINESS_EMAIL=hello@ateliernoir.com
BUSINESS_NAME=Atelier Noir
